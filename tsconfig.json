{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "outDir": "dist-tsc",
    "rootDir": ".",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["shared/**/*.ts", "tasks/*/src/**/*.ts"],
  "exclude": ["tests/**/*.ts", "node_modules"]
}
